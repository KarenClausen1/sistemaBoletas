{% set currentUser = app.user %}

<ul class="navbar-nav mr-auto">
    {% if currentUser %}
        <li class="nav-item">
            <a class="nav-link" href="{{ path('boleta_index') }}">Boletas</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('boleta_nueva') }}">Nueva boleta</a>
        </li>
    {% endif %}
</ul>

<ul class="navbar-nav ml-auto">
    {% if currentUser %}
        <li class="nav-item">
            <a class="nav-link" href="#">{{ currentUser.nombreUsuario }}</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">Salir</a>
        </li>
    {% else %}
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}">Iniciar sesión</a>
        </li>
    {% endif %}
</ul>
