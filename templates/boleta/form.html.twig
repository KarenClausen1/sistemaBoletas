{% extends 'base.html.twig' %}

{% block head %}
    <script src="{{ asset('js/functions.js') }}"></script>
    <script src="{{ asset('js/boleta.js') }}"></script>
{% endblock %}

{% block title %}Nueva Boleta{% endblock %}

{% block body %}

{{ form_start(form, { 'attr': {'onsubmit':'return validBoletaForm();','class': 'needs-validation'} }) }}

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
{% endfor %}

<div class="row mb-3 align-items-start">
    <div class="col-md-4">
        <div class="form-group">
            {{ form_label(form.numeroBoleta) }}
            {{ form_widget(form.numeroBoleta, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.numeroBoleta) }}
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            {{ form_label(form.profesional) }}
            {{ form_widget(form.profesional, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.profesional) }}
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            {{ form_label(form.fechaVencimiento) }}
            {{ form_widget(form.fechaVencimiento, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.fechaVencimiento) }}
        </div>
    </div>
</div>

<div class="row mb-3 align-items-start">
    <div class="col-md-12">
        <div class="alert alert-light border">
            <div class="font-weight-bold mb-2">Archivo principal</div>
            {{ form_label(form.archivoOriginal) }}
            {{ form_widget(form.archivoOriginal, {'attr': {'class': 'form-control-file'}}) }}
            {{ form_errors(form.archivoOriginal) }}

            {% if boleta and boleta.hasArchivoOriginal %}
                <div class="mt-2">
                    <a href="{{ path('boleta_archivo_original', {'id': boleta.id}) }}" class="btn btn-sm btn-outline-primary">Ver PDF / imagen actual</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% if form.comprobantePago is defined %}
    <div class="row mb-3 align-items-start">
        <div class="col-md-12">
            <div class="alert alert-light border">
                <div class="font-weight-bold mb-2">Comprobante de pago</div>
                {{ form_label(form.comprobantePago) }}
                {{ form_widget(form.comprobantePago, {'attr': {'class': 'form-control-file'}}) }}
                {{ form_errors(form.comprobantePago) }}

                {% if boleta and boleta.hasComprobante %}
                    <div class="mt-2">
                        <a href="{{ path('boleta_archivo_comprobante', {'id': boleta.id}) }}" class="btn btn-sm btn-outline-success">Descargar comprobante actual</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}

<div class="text-right mt-4">
    <a href="{{ path('boleta_index') }}" class="btn btn-outline-secondary">Cancelar</a>
    <button type="submit" class="btn btn-primary">{{ boleta and boleta.id ? 'Actualizar' : 'Guardar' }}</button>
</div>

{{ form_end(form) }}

{% endblock %}
